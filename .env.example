# --- Core services -----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5432/relay
DATABASE_URL_SYNC=postgresql+psycopg2://relay:relay@localhost:5432/relay
REDIS_URL=redis://localhost:6379/0

# --- Providers (all optional — mock provider needs nothing) -------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
MOCK_PROVIDER_URL=http://localhost:8100

# --- Spend safety --------------------------------------------------------------
# Hard kill-switch: adapters refuse any paid call once this daily total is hit.
MAX_DAILY_SPEND_USD=5.00

# --- Alerts --------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# --- Gateway -------------------------------------------------------------------
RELAY_HOST=0.0.0.0
RELAY_PORT=8080
ROUTING_CONFIG_PATH=config/routing.yaml
LOG_LEVEL=INFO
