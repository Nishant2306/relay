# --- Core services -----------------------------------------------------------
# host port 5433: Argus (companion project) uses 5432 on this machine
DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5433/relay
DATABASE_URL_SYNC=postgresql+psycopg2://relay:relay@localhost:5433/relay
REDIS_URL=redis://localhost:6379/0

# --- Providers (all optional — mock provider needs nothing) -------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# host ports 8200/8201 (Argus, the companion project, owns 8100 locally)
MOCK_PROVIDER_URL=http://localhost:8200
MOCK_PROVIDER_B_URL=http://localhost:8201

# --- Spend safety --------------------------------------------------------------
# Hard kill-switch: adapters refuse any paid call once this daily total is hit.
MAX_DAILY_SPEND_USD=5.00

# --- Alerts --------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# --- Gateway -------------------------------------------------------------------
ADMIN_KEY=relay-admin-dev-key
RELAY_HOST=0.0.0.0
RELAY_PORT=8080
ROUTING_CONFIG_PATH=config/routing.yaml
LOG_LEVEL=INFO
